# ┌─────────────────────────────────────────────────────┐
# │  OpenIM MCP Server + CLI — 环境配置                  │
# │  复制此文件为 .env 并修改实际值                        │
# └─────────────────────────────────────────────────────┘

# ── MCP 服务配置 ──────────────────────────────────────
# 传输协议：http / sse / stdio
MCP_TRANSPORT=http

# 仅当 MCP_TRANSPORT 为 "http" 或 "sse" 时生效
MCP_HOST=0.0.0.0
MCP_PORT=8079

# ── OpenIM 连接配置 ───────────────────────────────────
# OpenIM API 服务地址
OPENIM_API_ADDRESS=http://<OPENIM_SERVER_HOST>:10002

# OpenIM 管理员密钥（与 OpenIM 部署的 config.yaml / .env 中 secret 一致）
OPENIM_ADMIN_SECRET=<your_openim_secret>

# OpenIM 超级管理员 userID
OPENIM_ADMIN_ID=imAdmin

# ── 消息发送者身份 ────────────────────────────────────
# 发送消息时使用的 senderID（MCP 工具不可覆盖）
SENDER_ID=6122258426

# 平台 ID：5=普通用户端，12=机器人
BOT_PLATFORM_ID=5

# ── Token 缓存 ───────────────────────────────────────
# admin token 缓存时间（秒），到期前 5 分钟自动刷新
TOKEN_TTL_SECONDS=3600

# ── 性能参数 ─────────────────────────────────────────
# 并发发送消息的最大协程数
OPENIM_CONCURRENCY=50

# HTTP 请求超时（秒）
HTTP_TIMEOUT=30

# httpx 连接池最大连接数
HTTP_POOL_SIZE=100

# 连接保持活跃时间（秒）
HTTP_POOL_KEEPALIVE=30

# ── 安全策略 ─────────────────────────────────────────
# 是否允许私聊（session_type=1）。默认 false：只允许群聊
ALLOW_PRIVATE_CHAT=false

# 是否允许创建群组。默认 false，需显式开启
ALLOW_CREATE_GROUP=false

# 是否允许发送业务通知。默认 false，需显式开启
ALLOW_SEND_NOTIFICATION=false

# ── 日志 ─────────────────────────────────────────────
LOG_LEVEL=INFO
